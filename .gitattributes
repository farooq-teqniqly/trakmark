# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# .NET / C#
*.cs text eol=lf
*.csx text eol=lf
*.vb text eol=lf
*.fs text eol=lf
*.fsx text eol=lf
*.fsi text eol=lf
*.csproj text eol=lf
*.vbproj text eol=lf
*.fsproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.ruleset text eol=lf
*.editorconfig text eol=lf
*.globalconfig text eol=lf
*.resx text eol=lf
*.razor text eol=lf
*.cshtml text eol=lf
*.vbhtml text eol=lf
*.http text eol=lf

# Config / data
*.txt text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.xml text eol=lf

# Shell
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary — no diff, no line-ending mangling
*.wav binary
*.mp3 binary
*.mp4 binary
*.pyc binary
*.pyd binary
*.exe binary
*.dll binary
*.so binary
*.whl binary
*.nupkg binary
*.snupkg binary
*.pdb diff